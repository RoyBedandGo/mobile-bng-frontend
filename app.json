{
  "expo": {
    "name": "BNG",
    "slug": "bng-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bng-icon.png",
    "scheme": "bngmobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.RECORD_AUDIO"],
      "package": "com.bngsystem.bngmobileapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BedandGo to access your photos so you can upload inspection images.",
          "cameraPermission": "Allow BedandGo to access your camera to take photos of property items.",
          "microphonePermission": "Allow BedandGo to access your microphone to record video audio during inspections."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow BedandGo to access your photos and videos so you can save inspection media to your gallery.",
          "savePhotosPermission": "Allow BedandGo to save photos and videos to your gallery.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": ["photo", "video"]
        }
      ],
      "expo-video",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "487dee4e-1177-4978-ab68-643e8db5e242"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/487dee4e-1177-4978-ab68-643e8db5e242"
    }
  }
}
